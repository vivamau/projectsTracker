# ProjectsTracker Docker Environment Configuration
# Copy this file to .env or use these variables when running docker-compose

# ===== BACKEND CONFIGURATION =====

# Backend API JWT Secret (IMPORTANT: Change this in production!)
JWT_SECRET=change-this-to-a-secure-random-string-in-production

# JWT token expiration time
JWT_EXPIRES_IN=2h

# CORS allowed origin (must match the frontend URL)
# For local development: http://localhost
# For production: https://yourdomain.com
CORS_ORIGIN=http://localhost

# ===== FRONTEND CONFIGURATION =====

# Frontend port mapping (HOST:CONTAINER)
# Default: 80 (standard HTTP port)
# For local dev: 3000:80, 8080:80, etc. to avoid port conflicts
FRONTEND_PORT=80

# Vite API URL - build-time environment variable for the frontend
# IMPORTANT: This is baked into the frontend build!
# Empty string (default) = relative paths like /api/* (proxied through Nginx)
# Absolute URL = http://backend:5000 (only works in internal Docker network)
VITE_API_URL=

# ===== OPTIONAL: DATABASE =====

# Database location inside the container
# Default: /app/data/database.sqlite (persisted via Docker volume)
# Usually no need to change this
# DB_PATH=/app/data/database.sqlite

# ===== USAGE NOTES =====

# 1. Create .env file from this template:
#    cp .env.docker.sample .env
#
# 2. For local development on macOS/Linux:
#    - Leave FRONTEND_PORT=80 (requires sudo) or change to 8080
#    - Leave CORS_ORIGIN=http://localhost
#    - Leave VITE_API_URL empty (uses Nginx proxy)
#
# 3. For production deployment:
#    - Change JWT_SECRET to a strong random string
#    - Set CORS_ORIGIN to your production domain (https://yourdomain.com)
#    - Use a process manager (PM2, systemd) to manage docker-compose
#
# 4. Run the stack:
#    docker compose up --build
#
# 5. Access the application:
#    http://localhost (or http://localhost:8080 if using FRONTEND_PORT=8080)
#    Default login: admin@projecttracker.it / adminpassword
